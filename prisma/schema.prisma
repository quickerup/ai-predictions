generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id        String   @id @default(uuid())
  email     String   @unique
  apiKey    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Predictor {
  id          String           @id @default(uuid())
  name        String           @unique
  provider    String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  predictions Prediction[]
  score       PredictorScore?
}

model Category {
  id          String       @id @default(uuid())
  name        String       @unique
  parentId    String?
  parent      Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[]   @relation("CategoryHierarchy")
  
  predictions Prediction[]
  createdAt   DateTime     @default(now())
}

model Prediction {
  id          String   @id @default(uuid())
  claim       String
  probability Float
  eventDate   DateTime
  createdAt   DateTime @default(now()) // Immutable record, no updatedAt
  
  predictorId String
  predictor   Predictor @relation(fields: [predictorId], references: [id])
  
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  
  resolutionEdits ResolutionEdit[]
}

model ResolutionEdit {
  id           String     @id @default(uuid())
  outcome      String     // e.g., "TRUE", "FALSE", "AMBIGUOUS"
  sourceUrl    String
  createdAt    DateTime   @default(now()) // Append-only log
  
  predictionId String
  prediction   Prediction @relation(fields: [predictionId], references: [id])
}

model PredictorScore {
  id               String    @id @default(uuid())
  brierScore       Float     @default(0)
  accuracy         Float     @default(0)
  totalPredictions Int       @default(0)
  calculatedAt     DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  predictorId      String    @unique
  predictor        Predictor @relation(fields: [predictorId], references: [id])
}
